# Application Settings
APP_NAME=Vehicle Emission Analyzer
APP_VERSION=1.0.0
DEBUG=false

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgres://postgres:postgres@db:5432/emissions

# File Storage
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=500

# Video Processing
FRAME_SKIP=5
CONFIDENCE_THRESHOLD=0.5

# YOLOv8 Model
# Options: yolov8n.pt (fast), yolov8s.pt, yolov8m.pt, yolov8l.pt, yolov8x.pt (accurate)
YOLO_MODEL=yolov8n.pt

# DeepSORT Settings
MAX_AGE=30
N_INIT=3
MAX_COSINE_DISTANCE=0.3

# Emission Calculation
ASSUMED_SPEED_KMH=30.0
